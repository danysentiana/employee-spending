<%- include ('page-header.ejs') %>

<script>
    var isi = localStorage.getItem("token");
    if (parseJwt(isi).role != 1) {
        $(location).attr('href', "/error/401");
    }
</script>
<div class="content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">
                <div class="page-title-box">
                    <div class="page-title-right">
                        <ol class="breadcrumb m-0">
                            <li class="breadcrumb-item"><a href="javascript: void(0);">Master Data</a></li>
                            <li class="breadcrumb-item active">Regional</li>
                        </ol>
                    </div>
                    <h4 class="page-title">Regional</h4>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="mb-3">
                                <button id="add_button" type="button" class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#modal-add">Add </button>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-2">
                                <div class="mb-3">
                                    <label for="search_area" class="form-label">Area</label>
                                    <select name="search_area" id="search_area" class="form-select form-select-sm listArea">
                                        <option value="">--ALL--</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="mb-3">
                                    <label for="search_name_regional" class="form-label">Name Regional</label>
                                    <input id="search_name_regional" type="text" class="form-control form-control-sm" name="search_name_regional" placeholder="example: SUMBAGUT"/>
                                </div>
                            </div>
                            <div class="col-2">
                                <div class="mb-3">
                                    <label for="search_status" class="form-label">Status</label>
                                    <select name="search_status" id="search_status" class="form-select form-select-sm">
                                        <option value="">--ALL--</option>
                                        <option value="1">Active</option>
                                        <option value="0">Non Active</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        <button id="search_data" type="button" class="btn btn-dark" tabindex="0" style="float: right;">Search </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-striped table-sm table-bordered 
                                table-centered w-100 dt-responsive nowrap" id="regional-datatable">
                                <thead align="center">
                                    <tr>
                                        <th>No</th>
                                        <th>Area</th>
                                        <th>Regional</th>
                                        <th>Name Regional</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody align="center">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="modal-add" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myLargeModalLabel">Tambah</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
            </div>
            <div class="modal-body" id="modal-add-body">
                <form id="form_add">
                    <div class="row">
                        <input type="text" id="add_id" name="add_id" value="" hidden>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="add_area" class="form-label">Area</label>
                                <select id="add_area" name="add_area" class="form-select form-select-sm listArea" required>
                                </select>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="add_regional_name" class="form-label">Regional</label>
                                <input id="add_regional_name" type="text" class="form-control form-control-sm" 
                                name="add_regional_name" value="" 
                                placeholder="example: R01_Sumatera Bagian Utara"
                                required/>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="add_name_regional" class="form-label">Regional Name</label>
                                <input id="add_name_regional" type="text" class="form-control form-control-sm" 
                                name="add_name_regional" value="" 
                                placeholder="example: SUMBAGUT"
                                required/>
                            </div>
                        </div>
                    </div>
                    <button id="add_button" type="submit" class="btn btn-dark" tabindex="0" style="float: right;" class="mb-4">Submit </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modal-edit" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="myLargeModalLabel">Edit</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
            </div>
            <div class="modal-body" id="modal-edit-body">
                <form id="form_edit">
                    <div class="row">
                        <input type="text" id="edit_id" name="edit_id" value="" hidden>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="edit_area" class="form-label">Area</label>
                                <select id="edit_area" name="edit_area" class="form-select form-select-sm listArea" required>
                                </select>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="edit_regional_name" class="form-label">Regional</label>
                                <input id="edit_regional_name" type="text" class="form-control form-control-sm" 
                                name="edit_regional_name" value="" 
                                placeholder="R01_Sumatera Bagian Utara"
                                required/>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="edit_name_regional" class="form-label">Regional Name</label>
                                <input id="edit_name_regional" type="text" class="form-control form-control-sm" 
                                name="edit_name_regional" value="" 
                                placeholder="SUMBAGUT"
                                required/>
                            </div>
                        </div>
                    </div>
                    <button id="edit_button" type="submit" class="btn btn-dark" tabindex="0" style="float: right;" class="mb-4">Submit </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" src="/script/script-master-regional.js"></script>
<%- include ('page-footer.ejs') %>