    <style>
        #map {
            height: 500px;
            width: 100%;
        }

        .logo-lg img {
            height: 65px !important;
        }

        .btn-maroon {
            background-color: #295F99 !important;
            color: white !important;
        }

        .btn-maroon:hover {
            background-color: #204c7a !important;
            color: white !important;
        }

        .required:after {
            content: "*";
            color: red;
            margin-left: 2px;
        }

        .mykisel-blue {
            background-color: #295F99 !important;
        }

        /* Ensure navbar menu items have white text for contrast */
        .mykisel-blue .navbar-nav .nav-link {
            color: white !important;
        }

        .mykisel-blue .navbar-nav .nav-link:hover {
            color: #e3f2fd !important;
        }

        .mykisel-blue .navbar-nav .nav-item.active .nav-link {
            color: #bbdefb !important;
        }

        .mykisel-blue .dropdown-menu {
            background-color: #295F99 !important;
            border: 1px solid #1976d2 !important;
        }

        .mykisel-blue .dropdown-item {
            color: white !important;
        }

        .mykisel-blue .dropdown-item:hover {
            background-color: #1976d2 !important;
            color: white !important;
        }

        /* Change toggle dark mode and fullscreen icons to white */
        .mykisel-blue .topbar-menu .nav-link {
            color: white !important;
        }

        .mykisel-blue .topbar-menu .nav-link:hover {
            color: #e3f2fd !important;
        }

        .mykisel-blue .ri-moon-line,
        .mykisel-blue .ri-fullscreen-line {
            color: white !important;
        }

        .mykisel-blue .ri-moon-line:hover,
        .mykisel-blue .ri-fullscreen-line:hover {
            color: #e3f2fd !important;
        }
    </style>
</head>
<input type="checkbox" id="css-input" checked style="display: none"/>
