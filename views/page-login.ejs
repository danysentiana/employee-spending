<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Employee Spending Report APP</title>
    <link href="/assets/css/app-creative.css" rel="stylesheet" type="text/css">
    <link href="/assets/css/icons.min.css" rel="stylesheet" type="text/css">
    <style>
        body {
            background: #295F99;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Nunito', sans-serif;
        }

        .login-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            padding: 40px;
            max-width: 400px;
            width: 100%;
        }

        .login-title {
            text-align: center;
            margin-bottom: 30px;
            color: #295F99;
        }

        .login-title h1 {
            font-size: 24px;
            font-weight: bold;
            margin: 0;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 600;
        }

        .form-control {
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #295F99;
            box-shadow: 0 0 0 3px rgba(41, 95, 153, 0.1);
        }

        .btn-login {
            background: #295F99;
            border: none;
            color: white;
            padding: 12px 30px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: bold;
            width: 100%;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            background: #1e4a7a;
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(41, 95, 153, 0.3);
        }

        .input-group {
            display: flex;
            gap: 10px;
        }

        .input-group-text {
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            padding: 0 15px;
            cursor: pointer;
        }

        .input-group-text:hover {
            background: #e9ecef;
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper input {
            padding-right: 50px;
        }

        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #999;
            font-size: 20px;
            z-index: 10;
        }

        .password-toggle:hover {
            color: #295F99;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-title">
            <h1>Employee Spending Report APP</h1>
        </div>
        <form action="/login" method="post" id="form_login">
            <div class="form-group">
                <label for="login_username">Username</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="ri-user-line"></i></span>
                    <input type="text" class="form-control" id="login_username" name="login_username" required placeholder="Masukkan username">
                </div>
            </div>

            <div class="form-group">
                <label for="login_password">Password</label>
                <div class="password-wrapper">
                    <input type="password" class="form-control" id="login_password" name="login_password" required placeholder="Masukkan password">
                    <span class="password-toggle" onclick="showPassword()">
                        <i class="ri-eye-line" id="password_icon"></i>
                    </span>
                </div>
            </div>

            <div class="form-group">
                <button type="submit" id="login_button" class="btn-login">
                    <i class="ri-login-box-line me-2"></i> Login
                </button>
            </div>
        </form>
    </div>

    <!-- Vendor js -->
    <script src="/assets/js/vendor.min.js"></script>

    <!-- Sweetalert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Internal -->
    <script type="text/javascript" src="/script/script-login.js"></script>
</body>
</html>
