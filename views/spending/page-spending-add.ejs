<%- include('../page-header.ejs') %>

<div class="content">
    <div class="container-fluid">
        <div class="row py-3 align-items-center">
            <div class="col-12 col-md-6">
                <div class="page-title-box">
                    <h4 class="mb-0"><%= typeof spendingData !== 'undefined' ? 'Edit Pengeluaran' : 'Tambah Pengeluaran' %></h4>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Employee Spending / Transaksi / Pengeluaran</p>
                </div>
            </div>
            <div class="col-12 col-md-6 text-md-end mt-3 mt-md-0">
                <a href="/spending">
                    <button type="button" class="btn bg-white text-dark border me-2">
                        <i class="mdi mdi-arrow-left me-1"></i> Kembali
                    </button>
                </a>
                <button type="button" class="btn btn-primary" id="btn-save-spending" style="background-color: #295F99; border-color: #295F99;">
                    <i class="mdi mdi-content-save me-1"></i> Simpan
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Form Pengeluaran</h5>

                        <form id="form-spending">
                            <input type="hidden" name="spending_id" value="<%= typeof spendingData !== 'undefined' ? spendingData.spending_id : '' %>">
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Departemen <span class="text-danger">*</span></label>
                                    <div id="department-select-container">
                                        <select class="form-select" name="department_id" id="department-select" required>
                                            <option value="">Pilih Departemen</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Karyawan <span class="text-danger">*</span></label>
                                    <div id="employee-select-container">
                                        <select class="form-select" name="employee_id" id="employee-select" required>
                                            <option value="">Pilih Karyawan</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Tanggal <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="spending_date" 
                                        value="<%= typeof spendingData !== 'undefined' ? spendingData.spending_date : '' %>"
                                        required>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Nilai <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control format-number" name="value" 
                                        placeholder="Masukkan Nilai"
                                        value="<%= typeof spendingData !== 'undefined' ? spendingData.value : '' %>"
                                        required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Deskripsi</label>
                                <textarea class="form-control" name="description" rows="3" 
                                    placeholder="Masukkan Deskripsi (opsional)"><%= typeof spendingData !== 'undefined' ? spendingData.description : '' %></textarea>
                            </div>

                            <div class="alert alert-info" role="alert">
                                <i class="mdi mdi-information me-1"></i>
                                <small>Kolom dengan tanda <span class="text-danger">*</span> wajib diisi</small>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" src="/script/helper/script-auth.js"></script>
<script type="text/javascript" src="/script/helper/script-form-number-format.js"></script>
<script type="text/javascript" src="/script/spending/script-spending-add.js"></script>
<%- include('../page-footer.ejs') %>