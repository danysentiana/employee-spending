<%- include('../page-header.ejs') %>

<div class="content">
    <div class="container-fluid">
        <div class="row py-3 align-items-center">
            <div class="col-12 col-md-6">
                <div class="page-title-box">
                    <h4 class="mb-0"><%= typeof employeeData !== 'undefined' ? 'Edit Karyawan' : 'Tambah Karyawan' %></h4>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Employee Spending / Master Data / Karyawan</p>
                </div>
            </div>
            <div class="col-12 col-md-6 text-md-end mt-3 mt-md-0">
                <a href="/employee">
                    <button type="button" class="btn bg-white text-dark border me-2">
                        <i class="mdi mdi-arrow-left me-1"></i> Kembali
                    </button>
                </a>
                <button type="button" class="btn btn-primary" id="btn-save-employee" style="background-color: #295F99; border-color: #295F99;">
                    <i class="mdi mdi-content-save me-1"></i> Simpan
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Form Karyawan</h5>

                        <form id="form-employee">
                            <input type="hidden" name="employee_id" value="<%= typeof employeeData !== 'undefined' ? employeeData.employee_id : '' %>">
                            
                            <div class="mb-3">
                                <label class="form-label">Nama Karyawan <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="employee_name" 
                                    placeholder="Masukkan Nama Karyawan"
                                    value="<%= typeof employeeData !== 'undefined' ? employeeData.employee_name : '' %>"
                                    required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Departemen <span class="text-danger">*</span></label>
                                <select class="form-select" name="department_id" id="department-select" required>
                                    <option value="">Pilih Departemen</option>
                                </select>
                            </div>

                            <div class="alert alert-info" role="alert">
                                <i class="mdi mdi-information me-1"></i>
                                <small>Kolom dengan tanda <span class="text-danger">*</span> wajib diisi</small>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript" src="/script/helper/script-auth.js"></script>
<script type="text/javascript" src="/script/employee/script-employee-add.js"></script>
<%- include('../page-footer.ejs') %>