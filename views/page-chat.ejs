<script src="/socket.io/socket.io.js"></script>
<script>
  var socket = io();
  var d = new Date(); // for now

  var form = document.getElementById('form');
  var input = document.getElementById('input');
  var ul = document.getElementById("messages");

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (input.value) {
        socket.emit('Hii Rupinoz!!', $("#account-user-name").html(),input.value);
        input.value = '';
    }
  });

  socket.on('Hii Rupinoz!!', function(user,msg) {
    let msgFix = '<li class="clearfix odd">'+
                    '<div class="chat-avatar">'+
                        '<img src="../files/image/rupinoz.jpg" class="rounded" alt="dominic" />'+
                        '<i>'+d.getHours()+':'+d.getMinutes()+'</i>'+
                    '</div>'+
                    '<div class="conversation-text">'+
                        '<div class="ctext-wrap">'+
                            '<i>'+user+'</i>'+
                            '<p>'+msg+'</p>'+
                        '</div>'+
                    '</div>'+
                    '<div class="conversation-actions dropdown">'+
                        '<button class="btn btn-sm btn-link" data-bs-toggle="dropdown" aria-expanded="false"><i class="uil uil-ellipsis-v"></i></button>'+
                        '<div class="dropdown-menu">'+
                            '<a class="dropdown-item" href="#">Copy Message</a>'+
                            '<a class="dropdown-item" href="#">Edit</a>'+
                            '<a class="dropdown-item" href="#">Delete</a>'+
                        '</div>'+
                    '</div>'+
                '</li>';
    ul.innerHTML += msgFix;
    window.scrollTo(0, document.body.scrollHeight);
    // ul.scrollTo(0, ul.scrollHeight);
  });
</script>
